# ai-engine — example configuration
#
# Environment variables of the form $ {VAR_NAME} (no space — written here
# with a space in this comment to prevent self-substitution) are interpolated
# from the process environment at load time. Missing variables are a fatal
# startup error. Comments are NOT skipped by the interpolator, so any
# placeholder in this file must either be a real variable or be defanged
# (as above).

[server]
bind = "0.0.0.0:8080"
shutdown_grace_secs = 30
log_format = "json"        # "json" | "pretty"
log_level = "info"

[auth]
# "passthrough" — forward the inbound Authorization header to the upstream
# "shared-key"  — accept only the listed master keys
mode = "shared-key"
master_keys = [
  { key = "${AI_ENGINE_MASTER_KEY}", name = "default" },
]

[content_policy]
max_request_bytes = 1_048_576
prompt_injection_patterns = [
  "ignore (all )?previous instructions",
]

# --- Providers ---

[[provider]]
id = "openai-prod"
kind = "openai"
base_url = "https://api.openai.com/v1"
api_key = "${OPENAI_API_KEY}"
timeout_secs = 120
http2 = true

[[provider]]
id = "anthropic-prod"
kind = "anthropic"
base_url = "https://api.anthropic.com"
api_key = "${ANTHROPIC_API_KEY}"
timeout_secs = 120

# Local Ollama. Uncomment to enable. api_key is intentionally omitted —
# Ollama (and most local OpenAI-compatible servers) require no auth.
# [[provider]]
# id = "ollama-local"
# kind = "openai"
# base_url = "http://localhost:11434/v1"
# timeout_secs = 600       # local models can be slower; allow more time
# http2 = false            # Ollama defaults to http/1.1

# vLLM, LM Studio, Llama.cpp, OpenRouter — all OpenAI-shape, all configured
# the same way: kind = "openai" + the appropriate base_url + (optional) api_key.

# --- Routes (top-to-bottom, first match wins) ---

[[route]]
match = { model = "gpt-4o" }
provider = "openai-prod"
upstream_model = "gpt-4o-2024-08-06"

[[route]]
match = { model = "gpt-*" }
provider = "openai-prod"

[[route]]
match = { model = "text-embedding-*" }
provider = "openai-prod"

[[route]]
match = { model = "claude-*" }
provider = "anthropic-prod"

# [[route]]
# match = { model = "llama3*" }
# provider = "ollama-local"

# --- Pipelines (per endpoint) ---

[pipeline."/v1/chat/completions"]
stages = ["auth", "content_policy", "model_route", "forward", "log"]

[pipeline."/v1/messages"]
stages = ["auth", "content_policy", "model_route", "forward", "log"]

[pipeline."/v1/embeddings"]
stages = ["auth", "model_route", "forward", "log"]
